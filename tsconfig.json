{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/*"],
      "@shared/*": ["shared/*"],
      "@worker/*": ["worker/src/*"]
    },
    "types": ["vite/client", "@cloudflare/workers-types", "./worker-configuration"]
  },
  "include": [
    "src",
    "worker/src",
    "shared",
    "worker-configuration.d.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
